# ============================================
# Smart Invoice - 環境変数設定ガイド
# ============================================
# このファイルを .env.local にコピーして値を設定してください
# cp .env.example .env.local

# ---- Supabase ----
# https://supabase.com/dashboard でプロジェクトを作成
# Settings → API から取得
NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder-key
SUPABASE_SERVICE_ROLE_KEY=placeholder-key

# ---- Stripe ----
# https://dashboard.stripe.com/apikeys から取得
# 1. Stripeアカウント作成 → 本番利用には審査完了が必要
# 2. 商品を作成:
#    Stripe Dashboard → Products → Add Product
#    名前: "プロプラン" / 価格: ¥1,980/月 (recurring)
# 3. 作成した Price ID (price_xxx) を NEXT_PUBLIC_STRIPE_PRO_PRICE_ID に設定
# 4. Webhook を設定:
#    Stripe Dashboard → Developers → Webhooks → Add endpoint
#    URL: https://your-domain.com/api/stripe/webhook
#    イベント: checkout.session.completed, customer.subscription.updated,
#             customer.subscription.deleted, invoice.payment_failed
# 5. Webhook signing secret (whsec_xxx) を STRIPE_WEBHOOK_SECRET に設定
STRIPE_SECRET_KEY=sk_test_placeholder
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# ---- OpenAI ----
# https://platform.openai.com/api-keys から取得
# AI自動生成機能に使用（未設定時はモックデータで動作）
OPENAI_API_KEY=sk-placeholder

# ---- App ----
# ローカル開発: http://localhost:3000
# 本番: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
